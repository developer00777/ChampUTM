# Application
APP_NAME=ChampUTM
APP_VERSION=0.1.0
DEBUG=true
ENVIRONMENT=development

# PostgreSQL Database
# For local development, use these defaults
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=champutm
POSTGRES_PASSWORD=champutm_dev
POSTGRES_DB=champutm

# For Railway or other cloud platforms, set DATABASE_URL to override individual settings
# DATABASE_URL=postgresql://user:password@host:port/database

# JWT Authentication
# IMPORTANT: Change this in production! Must be at least 32 characters.
JWT_SECRET_KEY=your-secret-key-change-in-production-min-32-chars
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440  # 24 hours

# CORS - Frontend URL
# In development, defaults to localhost:3000
# In production, set to your actual frontend domain
FRONTEND_URL=http://localhost:3000
